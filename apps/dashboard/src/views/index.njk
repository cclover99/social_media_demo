<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        body{
            font-family: system-ui;
        }
        
        .table-container {
            margin-top: 10px;
            width: 100%;
            overflow-x: auto;
            border-radius: 8px;
            border: 1px solid #e5e7eb;
        }

        .logs-container {
            margin-top: 10px;
            width: 100%;
            overflow-x: auto;
            border-radius: 8px;
            border: 1px solid #e5e7eb; 
        }

        
        table {
            width: 100%;
            border-collapse: collapse;
            
            text-align: left;
            background-color: #ffffff;
        }

        
        thead {
            background-color: #f9fafb;
            border-bottom: 2px solid #e5e7eb;
        }

        th {
            padding: 14px 16px;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #4b5563;
        }

        td {
            padding: 16px;
            font-size: 0.95rem;
            color: #1f2937;
            
            white-space: nowrap;
        }

        tbody tr:hover {
            background-color: #f3f4f6;
            cursor: default;
        }

        tbody tr:nth-child(odd) {
            background-color: #e9e9e9 !important;
        }

        .pfp{
            height: 2.1rem;
            aspect-ratio: 1;
            margin: 0px;
            padding: 0px;
            object-fit: cover;
            border-radius: 50%;
            vertical-align: middle;
        }

        .username{
            color: black;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="table-container">
        <table>
            <thead>
                
                <tr>
                    <!-- <th>ID</th> -->
                    <th>Profile Picture</th>
                    <th>Username</th>
                    <th>Display Name</th>
                    <th>Email</th>
                    <th>Created At</th>
                </tr>
            </thead>
            <tbody>
                {# Loop through each user object in the data array #}
                {% for userdata in data %}
                    <tr>
                        <!-- <td>{{ userdata.user_id }}</td> -->
                        <td><img class="pfp" src="{{ ( CDN_HOST + '/profile_images/' + userdata.profile_pic) if userdata.profile_pic else CDN_HOST + '/images/default.jpg' }}"></td>
                        <td><a class="username">@{{ userdata.username }}</a></td>
                        <td>{{ userdata.display_name }}</td>
                        <td>{{ userdata.email }}</td>
                        <td>{{ userdata.register_date.toLocaleDateString() }}</td>
                        
                    </tr>
                {% else %}
                    {# This handles the edge case if the database returns 0 users #}
                    <tr>
                        <td colspan="5">No users found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

