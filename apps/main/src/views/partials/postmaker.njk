<style>
    #media-button{
        font-size: small;
        margin-right: 10px;
    }
</style>


<div class="postMaker">
    <form action="/api/create-post" method="POST" autocomplete = "off" enctype="multipart/form-data">
        <textarea 
            id="textarea"
            autocomplete = "off"
            name="content" 
            placeholder="What's on your mind?" 
            maxlength="400"
            style="width: 100%; height: 80px; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; resize: vertical; font-family: sans-serif; " ></textarea>
        <input autocomplete = "off" id="media-input" name="media" type="file" multiple accept="image/jpeg,image/png,image/gif,image/webp,image/avif,image/bmp,video/mp4" hidden>
        
        <div id="mediaPreview"></div>

        <div style="text-align: right; margin-top: 10px;">
            <span
                class="button"
                id="media-button"
                style="color: white; border: none;">
                Attach Media
            </span>
            <button
                id="submit"
                class="button"
                type="submit" 
                style="color: white; border: none;">
                Post
            </button>
        </div>
    </form>
</div>

<script>
    const media_uploader = document.getElementById("media-button");
    const media_input = document.getElementById("media-input");

    media_input.onchange = function(e){
        var file = e.target.files[0];
        if (!file) return;

        // const imageUrl = URL.createObjectURL(file);
        // document.querySelector('.large_pfp').src = imageUrl;
        
        var formData = new FormData();

        document.getElementById("mediaPreview").innerHTML = '';
        for (filename of e.target.files){
            const objectURL = URL.createObjectURL(filename);
            document.getElementById("mediaPreview").innerHTML += `<div><img src="${objectURL}"></div>`
            ;
        }
        
        formData.append('picture', file);
        console.log(e.target.files);
    };

    media_uploader.onclick = function(e){
        media_input.click();
    };

    document.getElementById("submit").addEventListener("click", function (e){
        if (!document.getElementById("textarea").value.trim() && !media_input.value){
            e.preventDefault();
            return false;
        };
    })

</script>