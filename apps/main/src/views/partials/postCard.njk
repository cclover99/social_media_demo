<div class="post{% if postType == 'detailed' %} detailed-view{% endif %}" post-id="{{ post.post_id }}" post-url="/u/{{ post.author_name }}/post/{{ post.post_id }}">
    <div style="height: auto; overflow: hidden;">
        <a href="/u/{{ post.author_name }}" style="float: left;" draggable="false">
            <img class="inline-pfp" src="{{ ( CDN_HOST + '/profile_images/' + post.avatar) if post.avatar else CDN_HOST + '/images/default.jpg' }}">{{ post.author_name }}</a
        >
            
        <span style="float:right;">
            <small>{{ post.publish_date | date }}</small>
        </span>
        <br>
        {% if ( user.id == post.author_id and postType == "detailed" ) %}
            <button class="deleteButton" type="submit">Delete Post</button>
        {% endif %}
    </div>
    {% if post.content %}
        <span style="cursor: text;">{{ post.content }}</span>
    {% endif %}
    
    {% if post.media %}
        <div id="gallery">
            {% for image in post.media | json %}
                <img src="{{ CDN_HOST }}/media/{{ image }}">
            {% endfor %}
        </div>
    {% endif %}
    <div class="action-buttons">
        <!-- Like Button -->
        <button data-action="like"
        {% if post.isLiked %} class="isLiked" {% endif %} 
        >Like {{ post.like_count }}</button>
        
        <button>Reply {{ post.comment_count }}</button>
        <button data-action="repost">Repost</button>
        
        <!-- Bookmark Button -->
        <button data-action="bookmark"
        {% if post.isBookmarked %} class="isBookmarked" {% endif %} 
        >Bookmark</button>
    </div>
</div>